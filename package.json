{
  "name": "memduck",
  "version": "0.1.2",
  "description": "A self-hosted personal memory engine for digesting external content into reusable memory.",
  "license": "MIT",
  "homepage": "https://github.com/tageecc/memduck#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tageecc/memduck.git"
  },
  "bugs": {
    "url": "https://github.com/tageecc/memduck/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "personal-knowledge",
    "self-hosted",
    "telegram",
    "browser-extension"
  ],
  "bin": {
    "memduck": "dist/cli.mjs"
  },
  "files": [
    ".env.example",
    ".next",
    "app",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "dist",
    "docs",
    "extension",
    "LICENSE",
    "next.config.ts",
    "next-env.d.ts",
    "public",
    "README.md",
    "README_zh.md",
    "SECURITY.md",
    "src",
    "tsconfig.json"
  ],
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "next build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm extension:build && pnpm cli:build && pnpm build",
    "cli:build": "node scripts/build-cli.mjs",
    "dev": "next dev",
    "extension:build": "node extension/scripts/build.mjs",
    "format": "biome format --write app src tests scripts extension/src extension/popup.html extension/popup.css extension/manifest.json extension/scripts next.config.ts package.json components.json postcss.config.mjs README.md README_zh.md biome.json",
    "lint": "biome check app src tests scripts extension/src extension/popup.html extension/popup.css extension/manifest.json extension/scripts next.config.ts",
    "logos:generate": "node scripts/generate-channel-logos.mjs && node scripts/generate-provider-logos.mjs",
    "memduck": "tsx scripts/cli.ts",
    "prepack": "pnpm cli:build && pnpm build && node scripts/clean-package-build.mjs",
    "telegram:dev": "tsx scripts/telegram.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "worker:dev": "tsx scripts/worker.ts"
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.11",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@types/better-sqlite3": "7.6.13",
    "ai": "^6.0.168",
    "better-sqlite3": "12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "grammy": "1.42.0",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "simple-icons": "^16.18.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/chrome": "0.1.40",
    "@types/jsdom": "^28.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.0",
    "tailwindcss": "^4.2.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
